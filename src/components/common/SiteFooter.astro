---
import { navItems, siteConfig, whatsappUrl } from "@/data/site";
---

<footer class="site-footer">
  <div class="container-shell site-footer__grid">
    <div class="site-footer__brand">
      <img src="/images/brand/logo-dory-sport.png" alt="Logo de Dory Sport" width="120" height="120" />
      <p>Oficio textil, bordados y confección personalizada desde Puerto Montt.</p>
    </div>

    <nav aria-label="Secciones del sitio">
      <p class="footer-label">Navegación</p>
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div>
      <p class="footer-label">Contacto</p>
      <p>{siteConfig.location}</p>
      <a href={whatsappUrl} target="_blank" rel="noreferrer">{siteConfig.whatsappDisplay}</a>
      <a href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">@tienda.dory_sport</a>
    </div>
  </div>

  <div class="container-shell site-footer__bottom">
    <span>© {new Date().getFullYear()} Dory Sport</span>
    <span>Hecho con oficio en el sur de Chile</span>
  </div>
</footer>
