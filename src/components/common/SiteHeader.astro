---
import { navItems, siteConfig, whatsappUrl } from "@/data/site";
---

<header class="site-header" data-site-header>
  <div class="container-shell site-header__inner">
    <a class="brand-lockup" href="/#inicio" aria-label="Ir al inicio de Dory Sport">
      <img
        class="brand-lockup__mark"
        src="/images/brand/logo-dory-sport.png"
        alt=""
        width="72"
        height="72"
      />
      <span class="brand-lockup__copy">
        <strong>{siteConfig.name}</strong>
        <small>Bordados y confección</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a href={item.href} data-nav-link>{item.label}</a>
      ))}
    </nav>

    <a class="button-primary site-header__cta" href={whatsappUrl} target="_blank" rel="noreferrer">
      Cotizar
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-controls="mobile-menu"
      aria-expanded="false"
      data-menu-toggle
    >
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" data-mobile-menu>
    <nav class="container-shell" aria-label="Navegación móvil">
      {navItems.map((item, index) => (
        <a href={item.href} data-nav-link data-menu-link>
          <span>0{index + 1}</span>{item.label}
        </a>
      ))}
      <a class="button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
        Cotizar por WhatsApp
      </a>
    </nav>
  </div>
</header>
