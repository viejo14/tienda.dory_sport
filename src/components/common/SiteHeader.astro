---
import { navItems, siteConfig, whatsappUrl } from "@/data/site";

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-black/5 bg-[#fcf8f2]/85 backdrop-blur-xl">
  <div class="container-shell flex items-center justify-between gap-6 py-4">
    <a class="flex items-center gap-3" href="/">
      <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[var(--color-ink)] text-sm font-extrabold tracking-[0.18em] text-[var(--color-latte)]">
        DS
      </div>
      <div>
        <p class="font-display text-2xl leading-none">{siteConfig.name}</p>
        <p class="mt-1 text-xs uppercase tracking-[0.26em] text-[var(--color-ink-soft)]">
          Bordados y confeccion
        </p>
      </div>
    </a>

    <nav class="hidden items-center gap-7 lg:flex">
      {
        navItems.map((item) => {
          const isActive = pathname === item.href;
          return (
            <a
              href={item.href}
              class:list={[
                "text-sm font-semibold transition-colors duration-200",
                isActive ? "text-[var(--color-ink)]" : "text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <a class="button-primary hidden lg:inline-flex" href={whatsappUrl} target="_blank" rel="noreferrer">
      Cotizar por WhatsApp
    </a>
  </div>
</header>
