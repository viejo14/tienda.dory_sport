---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/common/PageHero.astro";
import { seoByPage, services } from "@/data/site";
---

<BaseLayout meta={seoByPage.services}>
  <PageHero
    eyebrow="Servicios"
    title="Bordados, confeccion y prendas personalizadas con criterio comercial."
    copy="La oferta de Dory Sport combina trabajo a medida para clientes particulares con produccion orientada a marcas, pymes y equipos que necesitan verse consistentes."
  />

  <section class="container-shell py-12 md:py-20">
    <div class="grid gap-5 lg:grid-cols-2">
      {services.map((service) => (
        <article class="card-surface rounded-[2rem] p-8">
          <h2 class="font-display text-4xl leading-none">{service.title}</h2>
          <p class="mt-4 text-base leading-8 text-[var(--color-ink-soft)]">{service.description}</p>
          <ul class="mt-6 grid gap-3 text-sm font-semibold text-[var(--color-ink)] sm:grid-cols-2">
            {service.bullets.map((bullet) => <li>• {bullet}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
