---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/common/PageHero.astro";
import { seoByPage, showcaseItems } from "@/data/site";
---

<BaseLayout meta={seoByPage.catalog}>
  <PageHero
    eyebrow="Catalogo visual"
    title="Una muestra curada de prendas, bordados y presencia de marca."
    copy="Mientras reunimos fotografias reales del negocio, esta estructura deja lista una galeria limpia, editorial y escalable para exhibir trabajos terminados."
  />

  <section class="container-shell py-12 md:py-20">
    <div class="grid gap-6 md:grid-cols-2">
      {showcaseItems.map((item) => (
        <article class="overflow-hidden rounded-[2rem] border border-black/6 bg-white/70">
          <img class="h-[26rem] w-full object-cover" src={item.image} alt={item.alt} loading="lazy" />
          <div class="space-y-3 p-6">
            <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[var(--color-olive)]">{item.category}</p>
            <h2 class="font-display text-4xl leading-none">{item.title}</h2>
            <p class="text-sm leading-7 text-[var(--color-ink-soft)]">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
