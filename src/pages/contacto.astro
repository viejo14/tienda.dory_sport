---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/common/PageHero.astro";
import { seoByPage, siteConfig, whatsappUrl } from "@/data/site";
---

<BaseLayout meta={seoByPage.contact}>
  <PageHero
    eyebrow="Contacto"
    title="Una buena cotizacion parte por datos claros y una conversacion simple."
    copy="La V1 puede captar cotizaciones desde formulario y desde WhatsApp. Cuando tengamos datos finales del negocio, este bloque queda listo para operar en produccion."
  />

  <section class="container-shell py-12 md:py-20">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <article class="card-surface rounded-[2rem] p-8 md:p-10">
        <h2 class="font-display text-4xl leading-none">Canales de contacto</h2>
        <ul class="mt-6 space-y-4 text-sm leading-7 text-[var(--color-ink-soft)]">
          <li><strong class="text-[var(--color-ink)]">Ubicacion:</strong> {siteConfig.location}</li>
          <li>
            <strong class="text-[var(--color-ink)]">Instagram:</strong>
            <a class="ml-2 underline decoration-black/20 underline-offset-4" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
              tienda.dory_sport
            </a>
          </li>
          <li><strong class="text-[var(--color-ink)]">WhatsApp:</strong> configurar numero comercial</li>
          <li><strong class="text-[var(--color-ink)]">Horario:</strong> por definir con la clienta</li>
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
            Abrir WhatsApp
          </a>
          <a class="button-secondary" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
            Ver Instagram
          </a>
        </div>
      </article>

      <form
        class="card-surface grid gap-5 rounded-[2rem] p-8 md:grid-cols-2 md:p-10"
        name="cotizacion"
        method="POST"
        data-netlify="true"
      >
        <input type="hidden" name="form-name" value="cotizacion" />
        <div class="md:col-span-1">
          <label class="mb-2 block text-xs font-extrabold uppercase tracking-[0.18em] text-[var(--color-ink-soft)]" for="nombre">
            Nombre
          </label>
          <input class="w-full rounded-2xl border border-black/10 bg-white/70 px-4 py-3 outline-none" id="nombre" name="nombre" />
        </div>
        <div class="md:col-span-1">
          <label class="mb-2 block text-xs font-extrabold uppercase tracking-[0.18em] text-[var(--color-ink-soft)]" for="telefono">
            Telefono
          </label>
          <input class="w-full rounded-2xl border border-black/10 bg-white/70 px-4 py-3 outline-none" id="telefono" name="telefono" />
        </div>
        <div class="md:col-span-1">
          <label class="mb-2 block text-xs font-extrabold uppercase tracking-[0.18em] text-[var(--color-ink-soft)]" for="cliente">
            Tipo de cliente
          </label>
          <select class="w-full rounded-2xl border border-black/10 bg-white/70 px-4 py-3 outline-none" id="cliente" name="cliente">
            <option>Persona</option>
            <option>Pyme</option>
            <option>Empresa</option>
          </select>
        </div>
        <div class="md:col-span-1">
          <label class="mb-2 block text-xs font-extrabold uppercase tracking-[0.18em] text-[var(--color-ink-soft)]" for="cantidad">
            Cantidad estimada
          </label>
          <input class="w-full rounded-2xl border border-black/10 bg-white/70 px-4 py-3 outline-none" id="cantidad" name="cantidad" />
        </div>
        <div class="md:col-span-2">
          <label class="mb-2 block text-xs font-extrabold uppercase tracking-[0.18em] text-[var(--color-ink-soft)]" for="detalle">
            Detalle del pedido
          </label>
          <textarea class="min-h-40 w-full rounded-[1.5rem] border border-black/10 bg-white/70 px-4 py-3 outline-none" id="detalle" name="detalle"></textarea>
        </div>
        <div class="md:col-span-2 flex flex-wrap justify-between gap-4">
          <p class="max-w-xl text-sm leading-7 text-[var(--color-ink-soft)]">
            Este formulario queda listo para integrarse con Netlify Forms. Por ahora funciona como
            estructura base del proyecto.
          </p>
          <button class="button-primary" type="submit">Enviar solicitud</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
