---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionIntro from "@/components/common/SectionIntro.astro";
import {
  corporateBenefits,
  heroStats,
  instagramItems,
  instagramProfile,
  processSteps,
  seoByPage,
  services,
  showcaseItems,
  siteConfig,
  whatsappUrl,
} from "@/data/site";
---

<BaseLayout meta={seoByPage.home}>
  <section id="inicio" class="hero container-shell" data-section>
    <div class="hero__copy" data-hero-copy>
      <span class="eyebrow hero__eyebrow">Puerto Montt · Taller textil</span>
      <h1 class="hero__title" aria-label="Bordados y confección con oficio y voz propia">
        <span>Bordados y</span>
        <span>confección con</span>
        <span><em>oficio</em> y voz propia.</span>
      </h1>
      <p class="hero__lead">
        Prendas personalizadas, ropa deportiva y pedidos corporativos hechos con experiencia,
        cercanía y atención por cada detalle.
      </p>
      <div class="hero__actions">
        <a class="button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
          Cotizar por WhatsApp
          <span aria-hidden="true">↗</span>
        </a>
        <a class="text-link" href="/#trabajos">Ver trabajos <span aria-hidden="true">↓</span></a>
      </div>

      <div class="hero__stats" aria-label="Datos destacados">
        {heroStats.map((stat, index) => (
          <div style={`--delay: ${420 + index * 90}ms`}>
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <figure class="hero__visual" data-hero-visual data-parallax>
      <div class="hero__visual-label">
        <span>01</span>
        <span>Atelier Dory Sport</span>
      </div>
      <div class="hero__image-wrap">
        <img
          src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=1500&q=88"
          alt="Prendas textiles en perchas dentro de un atelier"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <figcaption>
        <span>Confección personalizada</span>
        <p>Para personas, equipos, pymes y empresas.</p>
      </figcaption>
    </figure>
  </section>

  <div class="craft-strip" aria-hidden="true">
    <div>
      <span>Bordado</span><i></i><span>Confección</span><i></i><span>Ropa deportiva</span><i></i>
      <span>Pedidos corporativos</span><i></i><span>Hecho en Puerto Montt</span><i></i>
      <span>Bordado</span><i></i><span>Confección</span><i></i><span>Ropa deportiva</span><i></i>
      <span>Pedidos corporativos</span><i></i><span>Hecho en Puerto Montt</span><i></i>
    </div>
  </div>

  <section id="servicios" class="section container-shell" data-section>
    <div class="services-layout">
      <div class="services-layout__intro">
        <SectionIntro
          eyebrow="Servicios"
          title="Del primer hilo a la prenda terminada."
          copy="Soluciones textiles personalizadas para necesidades distintas, siempre con atención directa y una terminación cuidada."
        />
        <p class="section-index" aria-hidden="true">02 / 06</p>
      </div>

      <div class="service-list">
        {services.map((service, index) => (
          <article class="service-row" data-reveal style={`--delay: ${index * 70}ms`}>
            <span class="service-row__number">0{index + 1}</span>
            <div class="service-row__body">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <ul>
                {service.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </div>
            <span class="service-row__arrow" aria-hidden="true">↗</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="empresas" class="business-section" data-section>
    <div class="container-shell business-panel">
      <div class="business-panel__heading" data-reveal>
        <span class="eyebrow eyebrow--light">Pymes y empresas</span>
        <h2>Tu identidad también puede vestirse.</h2>
        <p>
          Bordamos logos y confeccionamos prendas para equipos que necesitan verse consistentes,
          profesionales y reconocibles.
        </p>
        <a class="button-light" href={whatsappUrl} target="_blank" rel="noreferrer">
          Cotizar pedido corporativo <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="business-panel__benefits" data-reveal>
        <p class="micro-label">Qué podemos resolver</p>
        <ul>
          {corporateBenefits.map((benefit) => (
            <li><span aria-hidden="true">+</span>{benefit}</li>
          ))}
        </ul>
      </div>

      <div class="process-line">
        {processSteps.map((step, index) => (
          <article data-reveal style={`--delay: ${index * 90}ms`}>
            <span>0{index + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="trabajos" class="section container-shell" data-section>
    <div class="works-heading">
      <SectionIntro
        eyebrow="Selección de trabajos"
        title="Textiles con intención, forma y detalle."
        copy="Una muestra visual de las posibilidades que puede desarrollar Dory Sport para personas, marcas y equipos."
      />
      <a class="text-link" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
        Ver más en Instagram <span aria-hidden="true">↗</span>
      </a>
    </div>

    <div class="works-grid">
      {showcaseItems.map((item, index) => (
        <article class:list={["work-card", `work-card--${index + 1}`]} data-reveal style={`--delay: ${index * 80}ms`}>
          <div class="work-card__image">
            <img src={item.image} alt={item.alt} loading="lazy" />
          </div>
          <div class="work-card__meta">
            <span>{item.category}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="instagram-section">
    <div class="container-shell instagram-layout">
      <div class="instagram-copy" data-reveal>
        <span class="eyebrow">Instagram real</span>
        <h2>El taller también vive en redes.</h2>
        <p>
          En <strong>@{instagramProfile.username}</strong> puedes revisar publicaciones, prendas
          terminadas y novedades directamente desde la cuenta de Dory Sport.
        </p>
        <div class="instagram-profile-chip">
          <img src={instagramProfile.avatar} alt="Perfil de Dory Sport en Instagram" />
          <div>
            <strong>{instagramProfile.displayName}</strong>
            <span>{instagramProfile.location}</span>
          </div>
        </div>
        <a class="button-primary" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
          Visitar Instagram <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="instagram-grid" data-reveal>
        {instagramItems.map((item, index) => (
          <a href={item.href} target="_blank" rel="noreferrer" aria-label={item.caption} style={`--delay: ${index * 45}ms`}>
            <img src={item.image} alt={item.alt} loading="lazy" />
            <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="nosotros" class="section container-shell about-layout" data-section>
    <div class="about-layout__image" data-reveal data-parallax>
      <img src="/images/instagram/post-6.jpg" alt="Prenda confeccionada por Dory Sport" loading="lazy" />
      <span>Puerto Montt · Chile</span>
    </div>

    <div class="about-layout__copy" data-reveal>
      <span class="eyebrow">Nuestra historia</span>
      <p class="about-kicker">Más de tres décadas entre telas, máquinas e ideas.</p>
      <h2>Experiencia que se nota en cada terminación.</h2>
      <p>
        Dory Sport nace del oficio de una costurera con más de 30 años de experiencia. Su trabajo
        combina conocimiento técnico, cercanía y la flexibilidad de crear cada pedido según quien
        lo necesita.
      </p>
      <div class="about-signature">
        <span>30+</span>
        <p>años convirtiendo ideas en prendas reales</p>
      </div>
    </div>
  </section>

  <section id="contacto" class="contact-section container-shell" data-section data-reveal>
    <div class="contact-section__copy">
      <span class="eyebrow">Hablemos</span>
      <h2>Tu próximo pedido comienza con una conversación.</h2>
      <p>
        Cuéntanos qué necesitas y recibe orientación directa para tu prenda personalizada o pedido
        corporativo.
      </p>
    </div>
    <div class="contact-section__action">
      <span>WhatsApp directo</span>
      <a href={whatsappUrl} target="_blank" rel="noreferrer">
        {siteConfig.whatsappDisplay}<i aria-hidden="true">↗</i>
      </a>
      <p>{siteConfig.location}</p>
    </div>
  </section>

  <a class="whatsapp-float" href={whatsappUrl} target="_blank" rel="noreferrer" aria-label="Cotizar por WhatsApp">
    <span>WhatsApp</span>
    <i aria-hidden="true">↗</i>
  </a>
</BaseLayout>
