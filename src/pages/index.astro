---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionIntro from "@/components/common/SectionIntro.astro";
import {
  corporateBenefits,
  heroStats,
  instagramItems,
  instagramProfile,
  processSteps,
  seoByPage,
  services,
  showcaseItems,
  siteConfig,
  testimonials,
  whatsappUrl,
} from "@/data/site";
---

<BaseLayout meta={seoByPage.home}>
  <section class="container-shell grid min-h-[calc(100svh-5rem)] items-center gap-10 py-10 lg:grid-cols-[1.05fr_0.95fr] lg:py-16">
    <div class="space-y-8">
      <span class="eyebrow">Puerto Montt · Bordados · Confeccion</span>
      <div class="space-y-6">
        <h1 class="max-w-4xl font-display text-[clamp(3.6rem,10vw,7.2rem)] leading-[0.88] tracking-[-0.05em]">
          Una presencia textil con oficio, detalle y voz propia.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[var(--color-ink-soft)] md:text-xl">
          Dory Sport combina experiencia real en costura con una mirada limpia y comercial para
          bordados, ropa personalizada y pedidos corporativos.
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a class="button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
          Solicitar cotizacion
        </a>
        <a class="button-secondary" href="/empresas">Ver solucion para empresas</a>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {heroStats.map((stat) => (
          <article class="card-surface rounded-[1.4rem] p-5">
            <p class="font-display text-3xl leading-none">{stat.value}</p>
            <p class="mt-3 text-sm leading-6 text-[var(--color-ink-soft)]">{stat.label}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="grid-lines relative">
      <div class="relative overflow-hidden rounded-[2.2rem] bg-[var(--color-ink)] p-5 text-[var(--color-latte)] shadow-[0_30px_120px_rgba(16,33,43,0.28)]">
        <div class="mb-5 flex items-center justify-between text-xs uppercase tracking-[0.28em] text-white/55">
          <span>Atelier textil</span>
          <span>Edicion comercial</span>
        </div>
        <img
          class="h-[28rem] w-full rounded-[1.6rem] object-cover"
          src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=1400&q=80"
          alt="Prenda textil con enfoque de marca"
          loading="eager"
        />
        <div class="mt-5 grid gap-4 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <p class="font-display text-3xl">Confeccion y bordado con presencia de marca.</p>
            <p class="mt-3 max-w-xl text-sm leading-7 text-white/72">
              Prendas para personas, negocios y equipos que necesitan verse bien desde el acabado
              hasta la forma de presentarse.
            </p>
          </div>
          <a class="button-secondary border-white/15 bg-white/8 text-[var(--color-latte)]" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
            Ver Instagram
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell py-12 md:py-20">
    <SectionIntro
      eyebrow="Lo que hace Dory Sport"
      title="Una web comercial necesita mostrar oficio, pero tambien capacidad de respuesta."
      copy="Por eso la marca debe hablarle al cliente particular y al cliente empresa con la misma claridad: trabajo a medida, bordado profesional y una ejecucion que transmite confianza."
    />

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {services.map((service) => (
        <article class="card-surface rounded-[1.75rem] p-6">
          <h3 class="font-display text-3xl leading-tight">{service.title}</h3>
          <p class="mt-4 text-sm leading-7 text-[var(--color-ink-soft)]">{service.description}</p>
          <ul class="mt-5 space-y-3 text-sm font-semibold text-[var(--color-ink)]">
            {service.bullets.map((bullet) => <li>• {bullet}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="container-shell py-12 md:py-20">
    <div class="grid gap-8 lg:grid-cols-[0.86fr_1.14fr]">
      <div class="card-surface rounded-[2rem] p-8 md:p-10">
        <span class="eyebrow">Para pymes y empresas</span>
        <h2 class="mt-5 font-display text-5xl leading-[0.95] tracking-[-0.04em]">
          No solo prendas. Tambien imagen corporativa aplicada al textil.
        </h2>
        <p class="mt-5 text-base leading-8 text-[var(--color-ink-soft)]">
          Cuando una pyme necesita 40 pecheras, 40 gorros o una serie completa con bordado de
          marca, la decision pasa por confianza, prolijidad y consistencia. Esa es la narrativa que
          la web debe reforzar.
        </p>
        <ul class="mt-8 space-y-3 text-sm leading-7 text-[var(--color-ink)]">
          {corporateBenefits.map((item) => <li>• {item}</li>)}
        </ul>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button-primary" href="/empresas">Explorar solucion B2B</a>
          <a class="button-secondary" href={whatsappUrl} target="_blank" rel="noreferrer">Hablar ahora</a>
        </div>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        {showcaseItems.map((item, index) => (
          <article class:list={["overflow-hidden rounded-[2rem] border border-black/6 bg-white/70", index === 0 ? "md:col-span-2" : ""]}>
            <img class:list={["w-full object-cover", index === 0 ? "h-[24rem]" : "h-[18rem]"]} src={item.image} alt={item.alt} loading="lazy" />
            <div class="space-y-3 p-6">
              <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[var(--color-olive)]">{item.category}</p>
              <h3 class="font-display text-3xl leading-none">{item.title}</h3>
              <p class="text-sm leading-7 text-[var(--color-ink-soft)]">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container-shell py-12 md:py-20">
    <SectionIntro
      eyebrow="Metodo"
      title="Una ejecucion clara ayuda a vender mejor un servicio personalizado."
      copy="Para pedidos individuales o corporativos, mostrar el proceso reduce friccion y mejora la confianza. La web debe explicar como se avanza desde la idea hasta la entrega."
    />

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {processSteps.map((step, index) => (
        <article class="card-surface rounded-[1.75rem] p-6">
          <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[var(--color-sun)]">0{index + 1}</p>
          <h3 class="mt-5 font-display text-3xl leading-none">{step.title}</h3>
          <p class="mt-4 text-sm leading-7 text-[var(--color-ink-soft)]">{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-shell py-12 md:py-20">
    <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr]">
      <SectionIntro
        eyebrow="Redes sociales"
        title="Instagram sigue siendo vitrina, prueba social y ritmo de la marca."
        copy="La mejor solucion para esta marca es mostrar un bloque tipo perfil general: identidad, actividad y una grilla visual que recuerde al perfil real sin romper la estetica del sitio."
      />

      <div class="card-surface overflow-hidden rounded-[2.2rem] p-4 md:p-6">
        <div class="rounded-[1.7rem] border border-black/6 bg-white">
          <div class="border-b border-black/6 px-5 py-5">
            <div class="flex flex-col gap-5 md:flex-row md:items-start">
              <img
                class="h-20 w-20 rounded-full border border-black/8 bg-[var(--color-latte)] p-2"
                src={instagramProfile.avatar}
                alt={`Perfil de ${instagramProfile.username}`}
              />
              <div class="min-w-0 flex-1">
                <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                  <div class="min-w-0">
                    <p class="truncate text-lg font-extrabold text-[var(--color-ink)]">{instagramProfile.username}</p>
                    <p class="text-sm text-[var(--color-ink-soft)]">{instagramProfile.displayName} ({instagramProfile.location})</p>
                  </div>
                  <a class="button-primary !px-5 !py-3 !text-sm" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
                    Ver perfil
                  </a>
                </div>

                <div class="mt-5 grid gap-4 text-sm md:grid-cols-3">
                  <div>
                    <strong class="block text-[var(--color-ink)]">{instagramProfile.postsCount}</strong>
                    <span class="text-[var(--color-ink-soft)]">publicaciones</span>
                  </div>
                  <div>
                    <strong class="block text-[var(--color-ink)]">{instagramProfile.followers}</strong>
                    <span class="text-[var(--color-ink-soft)]">seguidores</span>
                  </div>
                  <div>
                    <strong class="block text-[var(--color-ink)]">{instagramProfile.following}</strong>
                    <span class="text-[var(--color-ink-soft)]">seguidos</span>
                  </div>
                </div>

                <div class="mt-5 space-y-1 text-sm leading-6 text-[var(--color-ink-soft)]">
                  {instagramProfile.bio.map((line) => <p>{line}</p>)}
                </div>
              </div>
            </div>

            <div class="mt-6 flex gap-4 overflow-x-auto pb-1">
              {instagramProfile.highlights.map((highlight) => (
                <div class="min-w-[5.5rem] text-center">
                  <img
                    class="mx-auto h-18 w-18 rounded-full border border-black/8 object-cover p-1"
                    src={highlight.image}
                    alt={highlight.label}
                    loading="lazy"
                  />
                  <p class="mt-2 truncate text-xs font-semibold text-[var(--color-ink-soft)]">{highlight.label}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-2 gap-[2px] bg-black/6 md:grid-cols-3">
            {instagramItems.map((item) => (
              <a class="group relative block overflow-hidden bg-white" href={item.href} target="_blank" rel="noreferrer">
                <img
                  class="aspect-square w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                  src={item.image}
                  alt={item.alt}
                  loading="lazy"
                />
                <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/65 to-transparent px-3 pb-3 pt-8 opacity-0 transition duration-300 group-hover:opacity-100">
                  <p class="text-xs font-semibold leading-5 text-white">{item.caption}</p>
                </div>
              </a>
            ))}
          </div>

          <div class="flex items-center justify-between px-5 py-4">
            <p class="text-sm leading-6 text-[var(--color-ink-soft)]">
              Una vista general del perfil para reforzar actividad, variedad y confianza visual.
            </p>
            <a class="text-sm font-extrabold text-[var(--color-sun)]" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
              Abrir Instagram
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell py-12 md:py-20">
    <SectionIntro
      eyebrow="Confianza"
      title="La experiencia se tiene que sentir en el sitio, no solo declararse."
      copy="Por eso la propuesta visual mezcla sobriedad comercial, textura editorial y bloques de contenido bien jerarquizados."
    />

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {testimonials.map((item) => (
        <blockquote class="card-surface rounded-[1.8rem] p-7">
          <p class="font-display text-3xl leading-tight">“{item.quote}”</p>
          <footer class="mt-6 text-sm leading-6 text-[var(--color-ink-soft)]">
            <strong class="block text-[var(--color-ink)]">{item.author}</strong>
            <span>{item.role}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </section>

  <section class="container-shell pb-10 pt-8 md:pb-20">
    <div class="overflow-hidden rounded-[2.4rem] bg-[var(--color-ink)] p-8 text-[var(--color-latte)] md:p-14">
      <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
        <div>
          <span class="eyebrow text-white/65 before:bg-white/65">Siguiente paso</span>
          <h2 class="mt-5 font-display text-5xl leading-[0.95] tracking-[-0.04em] md:text-6xl">
            Si necesitas una prenda bien hecha, la conversacion parte por una buena cotizacion.
          </h2>
        </div>
        <div class="space-y-5">
          <p class="text-sm leading-7 text-white/70">
            Podemos orientar la web a pedidos personales, institucionales o corporativos, con una
            entrada directa a WhatsApp y formularios pensados para captar datos utiles.
          </p>
          <div class="flex flex-wrap gap-3">
            <a class="button-secondary border-white/15 bg-white/10 text-[var(--color-latte)]" href={whatsappUrl} target="_blank" rel="noreferrer">
              Cotizar ahora
            </a>
            <a class="button-secondary border-white/15 bg-transparent text-[var(--color-latte)]" href="/contacto">
              Ir a contacto
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
