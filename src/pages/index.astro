---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionIntro from "@/components/common/SectionIntro.astro";
import {
  corporateBenefits,
  heroStats,
  instagramItems,
  instagramProfile,
  processSteps,
  seoByPage,
  services,
  showcaseItems,
  siteConfig,
  testimonials,
  whatsappUrl,
} from "@/data/site";
---

<BaseLayout meta={seoByPage.home}>
  <section id="inicio" class="container-shell scroll-mt-28 grid min-h-[calc(100svh-5rem)] items-center gap-10 py-10 lg:grid-cols-[1.05fr_0.95fr] lg:py-16">
    <div class="space-y-8">
      <span class="eyebrow">Puerto Montt · Bordados · Confección</span>
      <div class="space-y-6">
        <h1 class="max-w-4xl font-display text-[clamp(3.6rem,10vw,7.2rem)] leading-[0.88] tracking-[-0.05em]">
          Una presencia textil con oficio, detalle y voz propia.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[var(--color-ink-soft)] md:text-xl">
          Dory Sport combina experiencia real en costura con una mirada limpia y comercial para
          bordados, ropa personalizada y pedidos corporativos.
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a class="button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
          Solicitar cotización
        </a>
        <a class="button-secondary" href="/#empresas">Ver solución para empresas</a>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {heroStats.map((stat) => (
          <article class="card-surface rounded-[1.4rem] p-5">
            <p class="font-display text-3xl leading-none">{stat.value}</p>
            <p class="mt-3 text-sm leading-6 text-[var(--color-ink-soft)]">{stat.label}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="card-surface overflow-hidden rounded-[2.2rem] p-4 shadow-[0_30px_120px_rgba(16,33,43,0.16)]">
      <div class="mb-4 flex items-center justify-between text-[0.68rem] font-extrabold uppercase tracking-[0.26em] text-[var(--color-olive)]">
        <span>Atelier textil</span>
        <span>Edición comercial</span>
      </div>
      <img
        class="h-[29rem] w-full rounded-[1.7rem] object-cover"
        src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=1400&q=80"
        alt="Selección editorial de prendas textiles en un entorno de marca"
        loading="eager"
      />
      <div class="mt-4 rounded-[1.7rem] bg-[rgba(255,255,255,0.82)] p-6">
        <p class="font-display text-[2.35rem] leading-[0.96] text-[var(--color-ink)]">
          Confección y bordado con presencia de marca.
        </p>
        <p class="mt-3 max-w-xl text-sm leading-7 text-[var(--color-ink-soft)]">
          Prendas para personas, negocios y equipos que necesitan verse bien desde el acabado
          hasta la forma de presentarse.
        </p>
        <div class="mt-5">
          <a class="button-secondary" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
            Ver Instagram
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="servicios" class="container-shell scroll-mt-28 py-12 md:py-20">
    <SectionIntro
      eyebrow="Servicios"
      title="Bordado, confección y desarrollo textil con un lenguaje claro y comercial."
      copy="La idea no es marear con demasiadas rutas. La home concentra lo esencial: qué hace Dory Sport, para quién trabaja y cómo tomar contacto."
    />

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {services.map((service) => (
        <article class="card-surface rounded-[1.75rem] p-6">
          <h3 class="font-display text-3xl leading-tight">{service.title}</h3>
          <p class="mt-4 text-sm leading-7 text-[var(--color-ink-soft)]">{service.description}</p>
          <ul class="mt-5 space-y-3 text-sm font-semibold text-[var(--color-ink)]">
            {service.bullets.map((bullet) => <li>• {bullet}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section id="empresas" class="container-shell scroll-mt-28 py-12 md:py-20">
    <div class="card-surface rounded-[2rem] p-8 md:p-10">
      <div class="grid gap-8 xl:grid-cols-[1fr_0.95fr] xl:items-end">
        <div>
          <span class="eyebrow">Para pymes y empresas</span>
          <h2 class="mt-5 max-w-3xl font-display text-5xl leading-[0.95] tracking-[-0.04em]">
            No solo prendas. También imagen corporativa aplicada al textil.
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-ink-soft)]">
            Cuando una pyme necesita pecheras, gorros o prendas bordadas por volumen, lo que busca
            es confianza, prolijidad y un resultado consistente.
          </p>
        </div>

        <div class="space-y-6">
          <ul class="grid gap-3 text-sm leading-7 text-[var(--color-ink)] md:grid-cols-2">
            {corporateBenefits.map((item) => <li>• {item}</li>)}
          </ul>
          <div class="flex flex-wrap gap-3">
            <a class="button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">Cotizar pedido empresa</a>
            <a class="button-secondary" href="/#contacto">Hablar ahora</a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {processSteps.map((step, index) => (
        <article class="card-surface rounded-[1.75rem] p-6">
          <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[var(--color-sun)]">0{index + 1}</p>
          <h3 class="mt-5 font-display text-3xl leading-none">{step.title}</h3>
          <p class="mt-4 text-sm leading-7 text-[var(--color-ink-soft)]">{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="trabajos" class="container-shell scroll-mt-28 py-12 md:py-20">
    <SectionIntro
      eyebrow="Trabajos"
      title="Una muestra visual breve, suficiente y bien ordenada."
      copy="En vez de abrir una página aparte de catálogo, aquí concentramos una selección visual que ayuda a entender el tipo de trabajo que realiza la marca."
    />

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {showcaseItems.map((item) => (
        <article class="overflow-hidden rounded-[2rem] border border-black/6 bg-white/70 shadow-[var(--shadow-soft)]">
          <img class="h-[18rem] w-full object-cover" src={item.image} alt={item.alt} loading="lazy" />
          <div class="space-y-3 p-5">
            <p class="text-[0.68rem] font-extrabold uppercase tracking-[0.22em] text-[var(--color-olive)]">{item.category}</p>
            <h3 class="font-display text-[2rem] leading-none">{item.title}</h3>
            <p class="text-sm leading-7 text-[var(--color-ink-soft)]">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container-shell py-12 md:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow justify-center">Redes sociales</span>
      <h2 class="mt-5 font-display text-[clamp(2.8rem,7vw,4.8rem)] leading-[0.96] tracking-[-0.03em]">
        Instagram sigue siendo vitrina, prueba social y ritmo de la marca.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-[var(--color-ink-soft)]">
        Aquí sí conviene mostrar contenido real. Por eso este bloque se comporta como una ventana
        al perfil de Dory Sport, mientras el resto del sitio conserva una dirección visual más
        editorial y controlada.
      </p>
    </div>

    <div class="mx-auto mt-10 max-w-5xl">
      <div class="card-surface overflow-hidden rounded-[2.2rem] p-4 md:p-6">
        <div class="rounded-[1.7rem] border border-black/6 bg-white">
          <div class="border-b border-black/6 px-5 py-5">
            <div class="flex flex-col gap-5 md:flex-row md:items-start">
              <img
                class="h-20 w-20 rounded-full border border-black/8 bg-[var(--color-latte)] p-2"
                src={instagramProfile.avatar}
                alt={`Perfil de ${instagramProfile.username}`}
              />
              <div class="min-w-0 flex-1">
                <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                  <div class="min-w-0">
                    <p class="truncate text-lg font-extrabold text-[var(--color-ink)]">{instagramProfile.username}</p>
                    <p class="text-sm text-[var(--color-ink-soft)]">{instagramProfile.displayName} ({instagramProfile.location})</p>
                  </div>
                  <a class="button-primary !px-5 !py-3 !text-sm" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
                    Ver perfil
                  </a>
                </div>

                <div class="mt-5 grid gap-4 text-sm md:grid-cols-3">
                  <div>
                    <strong class="block text-[var(--color-ink)]">{instagramProfile.postsCount}</strong>
                    <span class="text-[var(--color-ink-soft)]">publicaciones</span>
                  </div>
                  <div>
                    <strong class="block text-[var(--color-ink)]">{instagramProfile.followers}</strong>
                    <span class="text-[var(--color-ink-soft)]">seguidores</span>
                  </div>
                  <div>
                    <strong class="block text-[var(--color-ink)]">{instagramProfile.following}</strong>
                    <span class="text-[var(--color-ink-soft)]">seguidos</span>
                  </div>
                </div>

                <div class="mt-5 space-y-1 text-sm leading-6 text-[var(--color-ink-soft)]">
                  {instagramProfile.bio.map((line) => <p>{line}</p>)}
                </div>
              </div>
            </div>

            <div class="mt-6 flex gap-4 overflow-x-auto pb-1">
              {instagramProfile.highlights.map((highlight) => (
                <div class="min-w-[5.5rem] text-center">
                  <img
                    class="mx-auto h-18 w-18 rounded-full border border-black/8 object-cover p-1"
                    src={highlight.image}
                    alt={highlight.label}
                    loading="lazy"
                  />
                  <p class="mt-2 truncate text-xs font-semibold text-[var(--color-ink-soft)]">{highlight.label}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-2 gap-[2px] bg-black/6 md:grid-cols-3">
            {instagramItems.map((item) => (
              <a class="group relative block overflow-hidden bg-white" href={item.href} target="_blank" rel="noreferrer">
                <img
                  class="aspect-square w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                  src={item.image}
                  alt={item.alt}
                  loading="lazy"
                />
                <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/65 to-transparent px-3 pb-3 pt-8 opacity-0 transition duration-300 group-hover:opacity-100">
                  <p class="text-xs font-semibold leading-5 text-white">{item.caption}</p>
                </div>
              </a>
            ))}
          </div>

          <div class="flex items-center justify-between px-5 py-4">
            <p class="text-sm leading-6 text-[var(--color-ink-soft)]">
              Una vista general del perfil para reforzar actividad, variedad y confianza visual.
            </p>
            <a class="text-sm font-extrabold text-[var(--color-sun)]" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
              Abrir Instagram
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="nosotros" class="container-shell scroll-mt-28 py-12 md:py-20">
    <SectionIntro
      eyebrow="Nosotros"
      title="Más de 30 años de oficio, cercanía y cuidado por la terminación."
      copy="Detrás de Dory Sport hay experiencia real en costura y confección. Esa trayectoria permite resolver prendas personalizadas y pedidos para empresa con criterio, cercanía y una presentación confiable."
    />

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {testimonials.map((item) => (
        <blockquote class="card-surface rounded-[1.8rem] p-7">
          <p class="font-display text-3xl leading-tight">{`"${item.quote}"`}</p>
          <footer class="mt-6 text-sm leading-6 text-[var(--color-ink-soft)]">
            <strong class="block text-[var(--color-ink)]">{item.author}</strong>
            <span>{item.role}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </section>

  <section id="contacto" class="container-shell scroll-mt-28 pb-10 pt-8 md:pb-20">
    <div class="card-surface overflow-hidden rounded-[2.4rem] border border-black/6 bg-[rgba(255,255,255,0.72)] p-8 text-[var(--color-ink)] md:p-14">
      <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
        <div>
          <span class="eyebrow">Contacto</span>
          <h2 class="mt-5 font-display text-5xl leading-[0.95] tracking-[-0.04em] md:text-6xl">
            Conversemos tu idea por WhatsApp.
          </h2>
          <p class="mt-5 max-w-2xl text-sm leading-7 text-[var(--color-ink-soft)]">
            Si necesitas cotizar bordados, prendas personalizadas o un pedido para empresa,
            escríbenos directamente y te orientamos según lo que necesitas.
          </p>
        </div>

        <div class="rounded-[2rem] border border-[rgba(83,99,86,0.18)] bg-[rgba(83,99,86,0.1)] p-7 text-[var(--color-ink)] shadow-[0_18px_55px_rgba(83,99,86,0.12)]">
          <ul class="space-y-3 text-sm leading-7 text-[var(--color-ink-soft)]">
            <li><strong class="text-[var(--color-ink)]">WhatsApp:</strong> {siteConfig.whatsappDisplay}</li>
            <li><strong class="text-[var(--color-ink)]">Ubicación:</strong> {siteConfig.location}</li>
            <li>
              <strong class="text-[var(--color-ink)]">Instagram:</strong>
              <a class="ml-2 underline decoration-black/15 underline-offset-4" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
                tienda.dory_sport
              </a>
            </li>
          </ul>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
              Escribir por WhatsApp
            </a>
            <a class="button-secondary bg-white/55" href={siteConfig.instagramUrl} target="_blank" rel="noreferrer">
              Ver Instagram
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
